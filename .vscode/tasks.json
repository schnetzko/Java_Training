{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile Java",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "mkdir -p bin && find src -name '*.java' | xargs javac --release 21 -d bin"
      ],
      "options": {
        "cwd": "${workspaceFolder}/Java_Training",
        "env": {
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk-amd64"
        }
      },
      "problemMatcher": ["$javac"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
